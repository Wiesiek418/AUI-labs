<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="2">

        <createTable tableName="drivers">
            <column name="driverID" type="UUID">
                <constraints primaryKey="true" primaryKeyName="drivers__PK"/>
            </column>
            <column name="driverName" type="VARCHAR(1024)"/>
            <column name="driverSurname" type="INTEGER"/>
            <column name="driverNationality" type="INTEGER"/>
            <column name="driverWDCTitles" type="INTEGER"/>
            <column name="formulaTeam" type="UUID">
                <constraints foreignKeyName="drivers__formulaTeam__FK"
                             referencedTableName="formula_teams"
                             referencedColumnNames="id"
                             nullable="false"/>
            </column>
        </createTable>

    </changeSet>

</databaseChangeLog>
